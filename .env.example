# Callback to aqshara-server
VIDEO_WORKER_CALLBACK_BASE_URL=http://127.0.0.1:3000/api/v1
VIDEO_INTERNAL_SERVICE_TOKEN=local-video-internal-token

# Redis streams
REDIS_URL=redis://localhost:6379/0

# Object storage
R2_ENDPOINT=https://example.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET=aqshara-local

# OpenAI
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TIMEOUT_SEC=60

# Render and merge
VIDEO_RENDER_BACKEND=mock
VIDEO_RENDER_PROFILE=720p
VIDEO_RENDER_TIMEOUT_SEC=180
VIDEO_MERGE_TIMEOUT_SEC=120
VIDEO_AUDIO_SYNC_MAX_DRIFT_PCT=15
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe

# Daytona render backend
DAYTONA_API_URL=
DAYTONA_API_KEY=
DAYTONA_TARGET=
DAYTONA_PYTHON_VERSION=3.12
DAYTONA_RENDER_IMAGE=
DAYTONA_CREATE_TIMEOUT_SEC=300
DAYTONA_RENDER_CPU=2
DAYTONA_RENDER_MEMORY_GB=4
DAYTONA_RENDER_DISK_GB=8
